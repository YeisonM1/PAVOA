# Copia este archivo como .env.local y completa los valores
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SHOPIFY_DOMAIN=
# Token Storefront/Headless para el frontend publico. No usar aqui el Client Secret del app.
VITE_SHOPIFY_TOKEN=
VITE_APP_URL=
VITE_WHATSAPP_NUMBER=

# Credenciales del app de Dev Dashboard que usa el backend para pedir un access token Admin dinamico.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Opcional/legado. Si usas Dev Dashboard, el backend ya puede funcionar solo con CLIENT_ID + CLIENT_SECRET.
SHOPIFY_ADMIN_TOKEN=
# Para webhooks de Shopify en apps de Dev Dashboard, usa el Client Secret del app backend.
SHOPIFY_WEBHOOK_SECRET=
MP_ACCESS_TOKEN=
MP_EXPECTED_USER_ID=
MP_WEBHOOK_SECRET=
RESEND_API_KEY=
MAIL_PROVIDER=resend
MAIL_FROM_NAME=PAVOA
MAIL_FROM_EMAIL=onboarding@resend.dev
MAILTRAP_SANDBOX_API_TOKEN=
MAILTRAP_SANDBOX_INBOX_ID=
JWT_SECRET=
